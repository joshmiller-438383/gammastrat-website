# Sanity CMS Configuration
# Get these from https://sanity.io/manage → Your Project → API

# Public (exposed to browser) - safe to commit
NEXT_PUBLIC_SANITY_PROJECT_ID=fa41e7wa
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SITE_URL=https://gammastrat.com

# Private (server-side only) - NEVER commit .env.local
# Create an Editor token at: sanity.io/manage → API → Tokens
SANITY_API_TOKEN=your-sanity-editor-token-here

# Optional: Shopify Storefront API (for buy buttons)
# NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=gammastrat.myshopify.com
# NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=your-storefront-token-here
